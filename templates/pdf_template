<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ 'rtl' if lang == 'fa' else 'ltr' }}">
<head>
    <!-- تنظیمات اصلی صفحه -->
    <meta charset="UTF-8">
    <title>{{ tr['result_title'] }} {{ full_name }}</title>
    <!-- استایل‌های CSS برای PDF -->
    <style>
        /* استایل‌های پایه */
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            line-height: 1.6;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        /* استایل‌های عنوان */
        h2 {
            color: #333;
            text-align: center;
            margin-bottom: 30px;
        }
        /* استایل کارت اطلاعات کاربر */
        .user-info-card {
            background-color: #f5f5f5;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 5px;
        }
        /* استایل بخش برنامه عملیاتی */
        .action-plan {
            background-color: #f9f9f9;
            padding: 20px;
            border-radius: 5px;
        }
        /* استایل زیرعنوان‌ها */
        h4 {
            color: #444;
            margin-top: 0;
        }
        /* استایل متن توصیه‌ها */
        pre {
            white-space: pre-wrap;
            font-family: Arial, sans-serif;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- عنوان گزارش -->
        <h2>{{ tr['result_title'] }} {{ full_name }}</h2>

        <!-- کارت اطلاعات BMI -->
        <div class="user-info-card">
            <div>
                <strong>{{ tr['bmi'] }}: {{ bmi }}</strong><br>
                <strong>{{ tr['status'] }}: {{ tr[status] }}</strong>
            </div>
        </div>

        <!-- کارت اطلاعات شخصی -->
        <div class="user-info-card">
            <div>
                <strong>{{ tr['age'] }}: {{ age }} {{ 'سال' if lang == 'fa' else 'Years' }}</strong><br>
                <strong>{{ tr['height'] }}: {{ height }} cm</strong><br>
                <strong>{{ tr['weight'] }}: {{ weight }} kg</strong><br>
                <strong>{{ tr['condition'] }}: {{ tr.get(f'condition_{condition}', tr['condition_none']) }}</strong>
            </div>
        </div>

        <!-- بخش توصیه‌های تخصصی -->
        <div class="action-plan">
            <h4>📋 {{ 'توصیه‌های تخصصی' if lang == 'fa' else 'Professional Advice' }}</h4>
            <pre>{{ tr.get('advice_' + status.split('_')[1] + '_' + condition, tr['advice_' + status.split('_')[1] + '_none'])|trim }}</pre>
        </div>
    </div>
</body>
</html>
